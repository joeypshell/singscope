{
  "name": "singscope",
  "private": true,
  "version": "0.1.0",
  "description": "Private, local-first singing practice and pitch review PWA.",
  "license": "MIT",
  "homepage": "https://joeypshell.github.io/singscope/",
  "repository": {
    "type": "git",
    "url": "https://github.com/joeypshell/singscope.git"
  },
  "bugs": {
    "url": "https://github.com/joeypshell/singscope/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11.7 <12"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode pages",
    "generate:demo": "node scripts/generate-demo.mjs",
    "preview": "vite preview",
    "preview:pages": "vite preview --mode pages",
    "typecheck": "tsc -b --pretty false",
    "typecheck:supabase": "tsc -p supabase/tsconfig.json --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:supabase": "vitest run --config supabase/vitest.config.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:live-report": "vitest run tests/live/analysis-report.live.test.ts",
    "test:safari": "node tests/safari/run.mjs",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm typecheck:supabase && pnpm test && pnpm test:supabase && pnpm build:pages"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@zip.js/zip.js": "2.8.28",
    "dexie": "4.4.4",
    "dexie-react-hooks": "4.4.0",
    "midi-json-parser-broker": "4.0.132",
    "midi-json-parser-worker": "8.1.66",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "workbox-window": "7.4.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/selenium-webdriver": "4.35.6",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "selenium-webdriver": "4.46.0",
    "supabase": "2.109.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
