# Public browser configuration for the explicit analysis-report flow.
# Copy this file to .env.local and replace the project reference.
VITE_SINGSCOPE_REPORT_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/functions/v1/analysis-report

# Optional: set only when the Edge Function expects a Supabase publishable key.
# This value is bundled into the public app; never use a secret or service-role key.
# VITE_SINGSCOPE_REPORT_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLIC_KEY
