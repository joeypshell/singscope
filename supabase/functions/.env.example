# Exact browser origin used by the public report function during local testing.
REPORT_ALLOWED_ORIGIN=http://127.0.0.1:4173

# Local-development fallback only. Hosted deployments validate the scheduler's
# Vault-generated token through the private database RPC and must omit this.
# Replace with at least 32 random characters. Never commit the real value.
REPORT_CLEANUP_TOKEN=replace-with-a-random-cleanup-token-at-least-32-characters
